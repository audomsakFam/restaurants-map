{
  "name": "restaurants-map-react-express",
  "version": "1.0.0",
  "description": "",
  "workspaces": [
    "backend",
    "restaurants-map-react"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=restaurants-map-react",
    "build": "npm run build --workspace=backend && npm run build --workspace=restaurants-map-react",
    "start": "npm run start --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "setup": "npm install && npm run db:migrate && npm run db:generate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
